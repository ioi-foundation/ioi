{
  "name": "hypervisor-vscode-extension",
  "displayName": "Hypervisor VS Code Adapter",
  "description": "Hypervisor VS Code-family code editor adapter for Hypervisor sessions.",
  "version": "0.0.1",
  "publisher": "ioi",
  "engines": {
    "vscode": "^1.109.0"
  },
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "browser": "./extension.js",
  "extensionKind": [
    "ui",
    "workspace"
  ]
}
