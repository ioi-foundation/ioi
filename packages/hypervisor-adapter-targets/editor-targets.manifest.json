{
  "schemaVersion": "ioi.hypervisor.editor_targets.manifest.v1",
  "targetRoot": "packages/hypervisor-adapter-targets",
  "runtimeAuthority": "crates/node/src/bin/hypervisor-daemon.rs",
  "defaultEditorId": "vscode",
  "doctrine": [
    "Hypervisor App orchestrates code editors; it is not one of them.",
    "An editor opens an Environment; the editor target is mediated, never product identity or runtime truth.",
    "The customized VS Code is the flagship VS Code-family target — one entry in this registry, not the host.",
    "IOI daemon is the runtime authority and durable execution boundary.",
    "Legacy native embedding paths are extraction inventory and must not be revived.",
    "Tracked editor-target metadata, adapter source, and ignored local host artifacts live under packages/hypervisor-adapter-targets/; the root ide/ and root code-editor-adapters/ artifact paths are retired.",
    "The default editor is an org/user preference, not the adapter contract."
  ],
  "families": [
    {
      "id": "vscode-family",
      "label": "VS Code family",
      "launchKind": "electron-host",
      "status": "active",
      "adapterModule": "packages/hypervisor-adapter-targets/code-editors/vscode-extension",
      "installedExtensionDirName": "hypervisor-vscode-extension",
      "sourceFork": {
        "defaultPath": "packages/hypervisor-adapter-targets/vscode",
        "optionalForRuntimeLaunch": true,
        "upstream": "https://github.com/microsoft/vscode.git",
        "localBranchHint": "antigravity/main"
      },
      "packagedApp": {
        "defaultPath": "packages/hypervisor-adapter-targets/builds/VSCode-linux-x64",
        "binary": "packages/hypervisor-adapter-targets/builds/VSCode-linux-x64/bin/hypervisor",
        "requiredForRuntimeLaunch": true
      },
      "editors": [
        {
          "id": "vscode",
          "label": "VS Code",
          "flagship": true,
          "profile": "code-editors/profiles/vscode.json",
          "status": "active"
        },
        {
          "id": "vscode-insiders",
          "label": "VS Code Insiders",
          "profile": "code-editors/profiles/vscode-insiders.json",
          "status": "active"
        },
        {
          "id": "cursor",
          "label": "Cursor",
          "profile": "code-editors/profiles/cursor.json",
          "status": "declared"
        },
        {
          "id": "windsurf",
          "label": "Windsurf",
          "profile": "code-editors/profiles/windsurf.json",
          "status": "declared"
        },
        {
          "id": "devin",
          "label": "Devin",
          "profile": "code-editors/profiles/devin.json",
          "status": "declared"
        }
      ],
      "runtimeVariant": "packaged_electron"
    },
    {
      "id": "web",
      "label": "Web",
      "launchKind": "browser",
      "status": "active",
      "adapterModule": "packages/hypervisor-adapter-targets/code-editors/vscode-extension",
      "editors": [
        {
          "id": "vscode-browser",
          "label": "VS Code Browser",
          "profile": "code-editors/profiles/vscode-browser.json",
          "status": "active"
        }
      ],
      "runtimeVariant": "oss_openvscode"
    },
    {
      "id": "jetbrains-gateway",
      "label": "JetBrains (Gateway)",
      "launchKind": "jetbrains-gateway",
      "status": "declared",
      "adapterModule": "packages/hypervisor-adapter-targets/jetbrains",
      "editors": [
        {
          "id": "intellij",
          "label": "IntelliJ IDEA Ultimate",
          "status": "declared"
        },
        {
          "id": "goland",
          "label": "GoLand",
          "status": "declared"
        },
        {
          "id": "pycharm",
          "label": "PyCharm Professional",
          "status": "declared"
        },
        {
          "id": "phpstorm",
          "label": "PhpStorm",
          "status": "declared"
        },
        {
          "id": "rubymine",
          "label": "RubyMine",
          "status": "declared"
        },
        {
          "id": "webstorm",
          "label": "WebStorm",
          "status": "declared"
        },
        {
          "id": "clion",
          "label": "CLion",
          "status": "declared"
        },
        {
          "id": "rustrover",
          "label": "RustRover",
          "status": "declared"
        },
        {
          "id": "rider",
          "label": "Rider",
          "status": "declared"
        }
      ]
    },
    {
      "id": "ssh",
      "label": "SSH",
      "launchKind": "ssh",
      "status": "declared",
      "adapterModule": "packages/hypervisor-adapter-targets/ssh",
      "editors": [
        {
          "id": "ssh",
          "label": "SSH",
          "status": "declared"
        }
      ]
    }
  ],
  "lockedDecisions": {
    "oneTargetProvenFirst": "vscode-browser (oss_openvscode) is proven end-to-end before app breadth; others stay declared",
    "leasePrimitive": "capability_lease_ref (no parallel SessionAccessLease)",
    "browserRuntimeReproducible": "openvscode-server pinned commit/version/sha256, fetch-once, fail-closed",
    "adapterOwnership": "source-controlled hypervisor-vscode-extension; the upstream reference binary is reference-only, never vendored"
  }
}
