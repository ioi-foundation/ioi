{
  "name": "@ioi/agent-sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Installable IOI agent SDK facade over the unified runtime substrate.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "import": "./dist/agent.js",
      "require": "./dist/agent.cjs"
    },
    "./run": {
      "types": "./dist/run.d.ts",
      "import": "./dist/run.js",
      "require": "./dist/run.cjs"
    },
    "./thread": {
      "types": "./dist/thread.d.ts",
      "import": "./dist/thread.js",
      "require": "./dist/thread.cjs"
    },
    "./messages": {
      "types": "./dist/messages.d.ts",
      "import": "./dist/messages.js",
      "require": "./dist/messages.cjs"
    },
    "./computer-use": {
      "types": "./dist/computer-use.d.ts",
      "import": "./dist/computer-use.js",
      "require": "./dist/computer-use.cjs"
    },
    "./lifecycle-readiness": {
      "types": "./dist/lifecycle-readiness.d.ts",
      "import": "./dist/lifecycle-readiness.js",
      "require": "./dist/lifecycle-readiness.cjs"
    },
    "./workbench-integration": {
      "types": "./dist/workbench-integration.d.ts",
      "import": "./dist/workbench-integration.js",
      "require": "./dist/workbench-integration.cjs"
    },
    "./options": {
      "types": "./dist/options.d.ts",
      "import": "./dist/options.js",
      "require": "./dist/options.cjs"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js",
      "require": "./dist/errors.cjs"
    },
    "./substrate-client": {
      "types": "./dist/substrate-client.d.ts",
      "import": "./dist/substrate-client.js",
      "require": "./dist/substrate-client.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    }
  },
  "files": [
    "dist",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json --emitDeclarationOnly && node scripts/build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test --test-concurrency=1 test/*.mjs",
    "smoke:quickstart": "npm run build && node dist/quickstart-local.js"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "esbuild": "^0.24.0",
    "typescript": "^5.3.3"
  }
}
