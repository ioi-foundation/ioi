{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ioi.network/wallet/exchange-intent.schema.json",
  "title": "ExchangeIntent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "intent_id",
    "schema_version",
    "initiator_id",
    "account_id",
    "from_asset",
    "to_asset",
    "min_amount_out",
    "route_candidate_id",
    "candidate_evidence",
    "slippage_bps",
    "policy_hash",
    "risk_labels",
    "simulation_hash",
    "tx_intent_refs"
  ],
  "properties": {
    "intent_id": { "type": "string" },
    "schema_version": { "const": "ioi.wallet.protocol.v1" },
    "initiator_id": { "type": "string" },
    "account_id": { "type": "string" },
    "from_asset": { "$ref": "#/$defs/MoneyAmount" },
    "to_asset": { "type": "string" },
    "min_amount_out": { "$ref": "#/$defs/MoneyAmount" },
    "route_candidate_id": { "type": "string" },
    "candidate_evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/CandidateEvidence" },
      "minItems": 1
    },
    "slippage_bps": { "type": "integer", "minimum": 0 },
    "policy_hash": { "type": "string" },
    "risk_labels": {
      "type": "array",
      "items": { "type": "string" }
    },
    "simulation_hash": { "type": "string" },
    "tx_intent_refs": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "MoneyAmount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asset", "amount"],
      "properties": {
        "asset": { "type": "string" },
        "amount": { "type": "string" },
        "chain": { "type": "string" }
      }
    },
    "CandidateEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "source",
        "adapter_id",
        "observed_at",
        "expires_at",
        "coverage_state",
        "evidence_refs",
        "risk_labels",
        "claims"
      ],
      "properties": {
        "candidate_id": { "type": "string" },
        "source": { "type": "string" },
        "adapter_id": { "type": "string" },
        "observed_at": { "type": "string", "format": "date-time" },
        "expires_at": { "type": "string", "format": "date-time" },
        "coverage_state": {
          "enum": [
            "assessed",
            "unknown",
            "unassessed",
            "stale",
            "conflicting_sources"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "risk_labels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "claims": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
