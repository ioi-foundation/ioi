{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ioi.network/wallet/trade-intent.schema.json",
  "title": "TradeIntent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "intent_id",
    "schema_version",
    "initiator_id",
    "account_id",
    "venue_candidate_id",
    "candidate_evidence",
    "market",
    "side",
    "collateral",
    "policy_hash",
    "risk_labels"
  ],
  "properties": {
    "intent_id": { "type": "string" },
    "schema_version": { "const": "ioi.wallet.protocol.v1" },
    "initiator_id": { "type": "string" },
    "account_id": { "type": "string" },
    "venue_candidate_id": { "type": "string" },
    "candidate_evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/CandidateEvidence" },
      "minItems": 1
    },
    "market": { "type": "string" },
    "side": { "enum": ["buy", "sell", "long", "short"] },
    "collateral": { "$ref": "#/$defs/MoneyAmount" },
    "leverage": { "type": "string" },
    "margin_mode": { "enum": ["isolated", "cross"] },
    "max_loss": { "$ref": "#/$defs/MoneyAmount" },
    "policy_hash": { "type": "string" },
    "risk_labels": {
      "type": "array",
      "items": { "type": "string" }
    },
    "simulation_hash": { "type": "string" }
  },
  "$defs": {
    "MoneyAmount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asset", "amount"],
      "properties": {
        "asset": { "type": "string" },
        "amount": { "type": "string" },
        "chain": { "type": "string" }
      }
    },
    "CandidateEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "source",
        "adapter_id",
        "observed_at",
        "expires_at",
        "coverage_state",
        "evidence_refs",
        "risk_labels",
        "claims"
      ],
      "properties": {
        "candidate_id": { "type": "string" },
        "source": { "type": "string" },
        "adapter_id": { "type": "string" },
        "observed_at": { "type": "string", "format": "date-time" },
        "expires_at": { "type": "string", "format": "date-time" },
        "coverage_state": {
          "enum": [
            "assessed",
            "unknown",
            "unassessed",
            "stale",
            "conflicting_sources"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "risk_labels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "claims": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
