{
  "openapi": "3.1.0",
  "info": {
    "title": "wallet.network Protocol API",
    "version": "0.1.0",
    "description": "Product-facing wallet.network authority, capability, intent, and receipt API contracts."
  },
  "paths": {
    "/v1/authority/reviews": {
      "post": {
        "operationId": "createAuthorityReview",
        "summary": "Create an authority review for an intent candidate.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthorityReview" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authority review accepted.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthorityReview" }
              }
            }
          }
        }
      }
    },
    "/v1/authority/principal-bindings": {
      "post": {
        "operationId": "issuePrincipalAuthorityBinding",
        "summary": "Append a wallet control-root-signed principal-to-approval-authority binding version.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/IssuePrincipalAuthorityBindingParams" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Immutable principal authority binding proof accepted.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PrincipalAuthorityBindingProofV1" }
              }
            }
          }
        }
      }
    },
    "/v1/authority/principal-bindings/{binding_ref}/revoke": {
      "post": {
        "operationId": "revokePrincipalAuthorityBinding",
        "summary": "Append a root-signed revoked successor without mutating prior proof versions.",
        "parameters": [
          {
            "name": "binding_ref",
            "in": "path",
            "required": true,
            "schema": { "$ref": "#/components/schemas/PrincipalAuthorityBindingRef" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RevokePrincipalAuthorityBindingParams" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Immutable revoked successor proof accepted.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PrincipalAuthorityBindingProofV1" }
              }
            }
          }
        }
      }
    },
    "/v1/authority/principal-bindings/resolve": {
      "post": {
        "operationId": "resolvePrincipalAuthority",
        "summary": "Resolve a portable principal to a currently active approval authority, optionally pinned to exact immutable coordinates.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ResolvePrincipalAuthorityParams" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verified principal authority resolution receipt.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PrincipalAuthorityResolutionReceipt" }
              }
            }
          }
        }
      }
    },
    "/v1/authority/principal-bindings/{binding_ref}": {
      "get": {
        "operationId": "getPrincipalAuthorityBinding",
        "summary": "Fetch one immutable binding proof by canonical binding ref with an optional exact hash pin.",
        "parameters": [
          {
            "name": "binding_ref",
            "in": "path",
            "required": true,
            "schema": { "$ref": "#/components/schemas/PrincipalAuthorityBindingRef" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GetPrincipalAuthorityBindingParams" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Immutable principal authority binding proof receipt.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GetPrincipalAuthorityBindingReceipt" }
              }
            }
          }
        }
      }
    },
    "/v1/capability/leases": {
      "post": {
        "operationId": "issueCapabilityLease",
        "summary": "Issue a bounded capability lease.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CapabilityLease" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Capability lease issued.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CapabilityLease" }
              }
            }
          }
        }
      }
    },
    "/v1/capability/leases/{lease_id}/revoke": {
      "post": {
        "operationId": "revokeCapabilityLease",
        "summary": "Revoke a bounded capability lease.",
        "parameters": [
          {
            "name": "lease_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CapabilityLeaseRevocation" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Capability lease revoked.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CapabilityLeaseRevocation" }
              }
            }
          }
        }
      }
    },
    "/v1/exchange/intents": {
      "post": {
        "operationId": "createExchangeIntent",
        "summary": "Create an exchange intent from a route candidate.",
        "responses": {
          "200": {
            "description": "Exchange intent created.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ExchangeIntent" }
              }
            }
          }
        }
      }
    },
    "/v1/trade/intents": {
      "post": {
        "operationId": "createTradeIntent",
        "summary": "Create a trade intent from a venue or market candidate.",
        "responses": {
          "200": {
            "description": "Trade intent created.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TradeIntent" }
              }
            }
          }
        }
      }
    },
    "/v1/receipts": {
      "post": {
        "operationId": "createReceipt",
        "summary": "Create a wallet receipt.",
        "responses": {
          "200": {
            "description": "Wallet receipt created.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WalletReceipt" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AuthorityReview": {
        "$ref": "../schemas/authority-review.schema.json"
      },
      "CapabilityLease": {
        "$ref": "../schemas/capability-lease.schema.json"
      },
      "CapabilityLeaseRevocation": {
        "$ref": "../schemas/capability-lease-revocation.schema.json"
      },
      "WalletReceipt": {
        "$ref": "../schemas/wallet-receipt.schema.json"
      },
      "ExchangeIntent": {
        "$ref": "../schemas/exchange-intent.schema.json"
      },
      "TradeIntent": {
        "$ref": "../schemas/trade-intent.schema.json"
      },
      "PrincipalAuthorityBindingProofV1": {
        "$ref": "../schemas/principal-authority-binding-proof.schema.json"
      },
      "PrincipalAuthorityResolutionV1": {
        "$ref": "../schemas/principal-authority-resolution.schema.json"
      },
      "WalletBytes32": {
        "type": "array",
        "minItems": 32,
        "maxItems": 32,
        "items": { "type": "integer", "minimum": 0, "maximum": 255 }
      },
      "PrincipalAuthorityBindingRef": {
        "type": "string",
        "pattern": "^wallet\\.network://principal-authority-binding/[0-9a-f]{64}$"
      },
      "PrincipalAuthorityBindingCoordinates": {
        "type": "object",
        "additionalProperties": false,
        "required": ["binding_ref", "binding_version", "binding_hash"],
        "properties": {
          "binding_ref": { "$ref": "#/components/schemas/PrincipalAuthorityBindingRef" },
          "binding_version": { "type": "integer", "minimum": 1 },
          "binding_hash": { "$ref": "#/components/schemas/WalletBytes32" }
        }
      },
      "IssuePrincipalAuthorityBindingParams": {
        "type": "object",
        "additionalProperties": false,
        "required": ["proof"],
        "properties": {
          "proof": { "$ref": "#/components/schemas/PrincipalAuthorityBindingProofV1" }
        }
      },
      "RevokePrincipalAuthorityBindingParams": {
        "type": "object",
        "additionalProperties": false,
        "required": ["proof"],
        "properties": {
          "proof": { "$ref": "#/components/schemas/PrincipalAuthorityBindingProofV1" }
        }
      },
      "ResolvePrincipalAuthorityParams": {
        "type": "object",
        "additionalProperties": false,
        "required": ["request_id", "principal_ref", "authority_kind"],
        "properties": {
          "request_id": { "$ref": "#/components/schemas/WalletBytes32" },
          "principal_ref": {
            "type": "string",
            "maxLength": 300,
            "pattern": "^((worker|service|org|domain)://|agentgres://domain/)[A-Za-z0-9]([A-Za-z0-9._~:@-]*[A-Za-z0-9])?(/[A-Za-z0-9]([A-Za-z0-9._~:@-]*[A-Za-z0-9])?)*$"
          },
          "authority_kind": { "const": "approval" },
          "expected_coordinates": { "$ref": "#/components/schemas/PrincipalAuthorityBindingCoordinates" }
        }
      },
      "PrincipalAuthorityResolutionReceipt": {
        "type": "object",
        "additionalProperties": false,
        "required": ["request_id", "resolved_at_ms", "resolution"],
        "properties": {
          "request_id": { "$ref": "#/components/schemas/WalletBytes32" },
          "resolved_at_ms": { "type": "integer", "minimum": 1 },
          "resolution": { "$ref": "#/components/schemas/PrincipalAuthorityResolutionV1" }
        }
      },
      "GetPrincipalAuthorityBindingParams": {
        "type": "object",
        "additionalProperties": false,
        "required": ["request_id", "binding_ref"],
        "properties": {
          "request_id": { "$ref": "#/components/schemas/WalletBytes32" },
          "binding_ref": { "$ref": "#/components/schemas/PrincipalAuthorityBindingRef" },
          "expected_binding_hash": { "$ref": "#/components/schemas/WalletBytes32" }
        }
      },
      "GetPrincipalAuthorityBindingReceipt": {
        "type": "object",
        "additionalProperties": false,
        "required": ["request_id", "fetched_at_ms", "proof"],
        "properties": {
          "request_id": { "$ref": "#/components/schemas/WalletBytes32" },
          "fetched_at_ms": { "type": "integer", "minimum": 1 },
          "proof": { "$ref": "#/components/schemas/PrincipalAuthorityBindingProofV1" }
        }
      }
    }
  }
}
