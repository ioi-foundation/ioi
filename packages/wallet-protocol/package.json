{
  "name": "@ioi/wallet-protocol",
  "version": "0.1.0",
  "private": true,
  "description": "Canonical wallet.network protocol contracts, schemas, fixtures, and method registry.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas/*": "./schemas/*",
    "./openapi/wallet-network.openapi.json": "./openapi/wallet-network.openapi.json",
    "./fixtures/*": "./fixtures/*"
  },
  "files": [
    "dist",
    "schemas",
    "openapi",
    "fixtures"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test --test-concurrency=1 test/*.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "typescript": "^5.3.3"
  }
}
