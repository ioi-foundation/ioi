{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema://ioi/foundations/autonomous-system-activation-state/v1",
  "title": "AutonomousSystemActivationState",
  "description": "Daemon-owned lifecycle projection. Initialized state is not a live chain; active state names the first live chain without admitting runtime, membership, or network effects.",
  "x-ioi-schema-version": "ioi.autonomous-system-activation-state.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "activation_state_ref",
    "activation_state_root",
    "system_id",
    "genesis_ref",
    "manifest_ref",
    "admitted_manifest_root",
    "lifecycle_profile_ref",
    "sequence",
    "status",
    "predecessor_state_root",
    "transition_ref",
    "transition_root",
    "transition_receipt_ref",
    "transition_receipt_root",
    "active_profile_set_ref",
    "active_profile_set_root",
    "chain_ref",
    "live_chain_created",
    "node_membership_refs",
    "runtime_effect_admitted",
    "network_effect_admitted",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "ioi.autonomous-system-activation-state.v1" },
    "activation_state_ref": { "$ref": "#/$defs/stateRef" },
    "activation_state_root": { "$ref": "#/$defs/hash" },
    "system_id": { "$ref": "#/$defs/systemRef" },
    "genesis_ref": { "$ref": "#/$defs/genesisRef" },
    "manifest_ref": { "$ref": "#/$defs/packageReleaseRef" },
    "admitted_manifest_root": { "$ref": "#/$defs/hash" },
    "lifecycle_profile_ref": { "$ref": "#/$defs/lifecycleProfileRef" },
    "sequence": { "type": "integer", "minimum": 1, "maximum": 2 },
    "status": { "enum": ["initialized", "active"] },
    "predecessor_state_root": { "$ref": "#/$defs/hash" },
    "transition_ref": { "$ref": "#/$defs/transitionRef" },
    "transition_root": { "$ref": "#/$defs/hash" },
    "transition_receipt_ref": { "$ref": "#/$defs/receiptRef" },
    "transition_receipt_root": { "$ref": "#/$defs/hash" },
    "active_profile_set_ref": { "$ref": "#/$defs/nullableActiveProfileSetRef" },
    "active_profile_set_root": { "$ref": "#/$defs/nullableHash" },
    "chain_ref": { "$ref": "#/$defs/nullableChainRef" },
    "live_chain_created": { "type": "boolean" },
    "node_membership_refs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^node-membership://[^\\s]{1,248}$" },
      "maxItems": 0
    },
    "runtime_effect_admitted": { "const": false },
    "network_effect_admitted": { "const": false },
    "created_at": { "$ref": "#/$defs/canonicalDateTime" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "initialized" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "sequence": { "enum": [1] },
          "active_profile_set_ref": { "type": "null" },
          "active_profile_set_root": { "type": "null" },
          "chain_ref": { "type": "null" },
          "live_chain_created": { "const": false }
        }
      },
      "else": {
        "properties": {
          "sequence": { "enum": [2] },
          "active_profile_set_ref": { "$ref": "#/$defs/activeProfileSetRef" },
          "active_profile_set_root": { "$ref": "#/$defs/hash" },
          "chain_ref": { "$ref": "#/$defs/chainRef" },
          "live_chain_created": { "const": true }
        }
      }
    }
  ],
  "$defs": {
    "hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "nullableHash": { "anyOf": [{ "$ref": "#/$defs/hash" }, { "type": "null" }] },
    "systemRef": { "type": "string", "pattern": "^system://[^\\s]{1,248}$" },
    "genesisRef": { "type": "string", "pattern": "^genesis://[^\\s]{1,248}$" },
    "packageReleaseRef": { "type": "string", "pattern": "^package://[^\\s?#\\\\]{1,160}/release/sha256:[0-9a-f]{64}$" },
    "lifecycleProfileRef": { "type": "string", "pattern": "^lifecycle-profile://[^\\s]{1,248}$" },
    "stateRef": { "type": "string", "pattern": "^system-activation-state://[^\\s]{1,248}$" },
    "transitionRef": { "type": "string", "pattern": "^lifecycle-transition://[^\\s]{1,248}$" },
    "receiptRef": { "type": "string", "pattern": "^receipt://[^\\s]{1,248}$" },
    "activeProfileSetRef": { "type": "string", "pattern": "^active-profile-set://[^\\s]{1,248}$" },
    "nullableActiveProfileSetRef": { "anyOf": [{ "$ref": "#/$defs/activeProfileSetRef" }, { "type": "null" }] },
    "chainRef": { "type": "string", "pattern": "^autonomous-system-chain://[^\\s]{1,248}$" },
    "nullableChainRef": { "anyOf": [{ "$ref": "#/$defs/chainRef" }, { "type": "null" }] },
    "canonicalDateTime": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:(?:[0-5][0-9]|60)(?:[.][0-9]+|)(?:Z|[+-](?:[01][0-9]|2[0-3]):[0-5][0-9])$"
    }
  }
}
