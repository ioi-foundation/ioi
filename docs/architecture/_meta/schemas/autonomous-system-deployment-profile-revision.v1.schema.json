{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema://ioi/foundations/autonomous-system-deployment-profile-revision/v1",
  "title": "AutonomousSystemDeploymentProfileRevision",
  "description": "Immutable content-addressed candidate deployment profile. Declaration is not activation, membership, readiness, or runtime authority.",
  "x-ioi-schema-version": "ioi.autonomous-system-deployment-profile-revision.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "deployment_profile_ref",
    "deployment_profile_root",
    "profile"
  ],
  "properties": {
    "schema_version": {
      "const": "ioi.autonomous-system-deployment-profile-revision.v1"
    },
    "deployment_profile_ref": {
      "$ref": "#/$defs/deploymentProfileRevisionRef"
    },
    "deployment_profile_root": {
      "$ref": "#/$defs/hash"
    },
    "profile": {
      "$ref": "#/$defs/deploymentProfile"
    }
  },
  "$defs": {
    "hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "canonicalRef": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*(?:://|:)[^\\s]{1,248}$"
    },
    "policyRef": {
      "type": "string",
      "pattern": "^policy://[^\\s]{1,248}$"
    },
    "nullablePolicyRef": {
      "anyOf": [
        { "$ref": "#/$defs/policyRef" },
        { "type": "null" }
      ]
    },
    "systemRef": {
      "type": "string",
      "pattern": "^system://[^\\s]{1,248}$"
    },
    "constitutionRef": {
      "type": "string",
      "pattern": "^constitution://[^\\s]{1,248}$"
    },
    "packageReleaseRef": {
      "type": "string",
      "pattern": "^package://[^\\s?#\\\\]{1,160}/release/sha256:[0-9a-f]{64}$"
    },
    "orderingProfileRef": {
      "type": "string",
      "pattern": "^ordering-profile://[^\\s]{1,248}$"
    },
    "failoverProfileRef": {
      "type": "string",
      "pattern": "^failover-profile://[^\\s]{1,248}$"
    },
    "deploymentProfileId": {
      "type": "string",
      "pattern": "^deployment-profile://[^\\s?#\\\\]{1,160}$"
    },
    "deploymentProfileRevisionRef": {
      "type": "string",
      "pattern": "^deployment-profile://[^\\s?#\\\\]{1,160}/revision/sha256:[0-9a-f]{64}$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9A-Za-z][0-9A-Za-z.+_-]{0,63}$"
    },
    "roleRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "minimum_ready_nodes",
        "maximum_active_nodes",
        "placement_policy_ref",
        "failure_independence_policy_ref",
        "colocation_allowed"
      ],
      "properties": {
        "role": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9._-]{0,127}$"
        },
        "minimum_ready_nodes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535
        },
        "maximum_active_nodes": {
          "anyOf": [
            { "type": "integer", "minimum": 1, "maximum": 65535 },
            { "type": "null" }
          ]
        },
        "placement_policy_ref": { "$ref": "#/$defs/policyRef" },
        "failure_independence_policy_ref": { "$ref": "#/$defs/nullablePolicyRef" },
        "colocation_allowed": { "type": "boolean" }
      }
    },
    "deploymentProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "deployment_profile_id",
        "system_id",
        "constitution_ref",
        "manifest_ref",
        "version",
        "environment_class",
        "environment_and_custody_profile_ref",
        "ordering_admission_finality_profile_ref",
        "role_requirements",
        "state_distribution",
        "scaling",
        "membership_policy_ref",
        "failover_profile_ref",
        "partition_and_degraded_mode_policy_ref",
        "restore_policy_ref",
        "rollout_policy_ref",
        "rollback_policy_ref",
        "drain_and_removal_policy_ref",
        "receipt_obligations",
        "status"
      ],
      "properties": {
        "schema_version": {
          "const": "ioi.autonomous-system-deployment-profile.v1"
        },
        "deployment_profile_id": { "$ref": "#/$defs/deploymentProfileId" },
        "system_id": { "$ref": "#/$defs/systemRef" },
        "constitution_ref": { "$ref": "#/$defs/constitutionRef" },
        "manifest_ref": { "$ref": "#/$defs/packageReleaseRef" },
        "version": { "$ref": "#/$defs/version" },
        "environment_class": {
          "enum": ["development", "test", "staging", "production", "recovery"]
        },
        "environment_and_custody_profile_ref": { "$ref": "#/$defs/policyRef" },
        "ordering_admission_finality_profile_ref": { "$ref": "#/$defs/orderingProfileRef" },
        "role_requirements": {
          "type": "array",
          "items": { "$ref": "#/$defs/roleRequirement" },
          "maxItems": 64
        },
        "state_distribution": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "operation_log_replication_factor",
            "projection_replication_factor",
            "artifact_replication_factor",
            "minimum_ack_durability",
            "consistency_and_read_watermark_policy_ref",
            "checkpoint_policy_ref",
            "catchup_policy_ref"
          ],
          "properties": {
            "operation_log_replication_factor": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "projection_replication_factor": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "artifact_replication_factor": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "minimum_ack_durability": {
              "enum": ["buffered", "device_flush", "replicated_same_host", "quorum_replicated"]
            },
            "consistency_and_read_watermark_policy_ref": { "$ref": "#/$defs/policyRef" },
            "checkpoint_policy_ref": { "$ref": "#/$defs/policyRef" },
            "catchup_policy_ref": { "$ref": "#/$defs/policyRef" }
          }
        },
        "scaling": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode",
            "scaling_policy_ref",
            "eligible_automatic_roles",
            "authority_role_changes",
            "rebalance_policy_ref"
          ],
          "properties": {
            "mode": { "enum": ["manual", "policy_automated"] },
            "scaling_policy_ref": { "$ref": "#/$defs/policyRef" },
            "eligible_automatic_roles": {
              "type": "array",
              "items": {
                "enum": ["projection_replica", "execution_worker", "artifact_replica"]
              },
              "maxItems": 3,
              "uniqueItems": true
            },
            "authority_role_changes": { "const": "governed_only" },
            "rebalance_policy_ref": { "$ref": "#/$defs/policyRef" }
          }
        },
        "membership_policy_ref": { "$ref": "#/$defs/policyRef" },
        "failover_profile_ref": { "$ref": "#/$defs/failoverProfileRef" },
        "partition_and_degraded_mode_policy_ref": { "$ref": "#/$defs/policyRef" },
        "restore_policy_ref": { "$ref": "#/$defs/policyRef" },
        "rollout_policy_ref": { "$ref": "#/$defs/policyRef" },
        "rollback_policy_ref": { "$ref": "#/$defs/policyRef" },
        "drain_and_removal_policy_ref": { "$ref": "#/$defs/policyRef" },
        "receipt_obligations": {
          "type": "array",
          "items": { "$ref": "#/$defs/canonicalRef" },
          "maxItems": 64,
          "uniqueItems": true
        },
        "status": { "const": "draft" }
      }
    }
  }
}
