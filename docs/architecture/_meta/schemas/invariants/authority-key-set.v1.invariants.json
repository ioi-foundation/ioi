{
  "$id": "invariant://ioi/foundations/authority-key-set/validity-window/v1",
  "language": "ioi.portable-invariants.v1",
  "contract_id": "schema://ioi/foundations/authority-key-set/v1",
  "rules": [
    {
      "rule_id": "authority_key_set.issued_at.before_expiry",
      "description": "A key-discovery set must have a non-empty validity interval.",
      "expression": {
        "operator": "numbers_lt",
        "paths": ["$.issued_at", "$.expires_at"]
      }
    }
  ]
}
