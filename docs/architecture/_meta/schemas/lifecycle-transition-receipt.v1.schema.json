      "enum": [
        "initialized_not_active",
        "protected_lifecycle_committed"
      ]
    },
    "assurance_note": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "timestamp": {
      "$ref": "#/$defs/canonicalDateTime"
    },
    "outcome": {
      "const": "ok"
    },
    "at": {
      "$ref": "#/$defs/canonicalDateTime"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "op": {
            "const": "initialize"
          }
        },
        "required": [
          "op"
        ]
      },
      "then": {
        "properties": {
          "sequence": {
            "enum": [
              1
            ]
          },
          "required_scope": {
            "const": "scope:autonomous_system.lifecycle.initialize"
          },
          "authority_scopes": {
            "type": "array",
            "items": {
              "const": "scope:autonomous_system.lifecycle.initialize"
            },
            "minItems": 1,
            "maxItems": 1
          },
          "bound_facts": {
            "$ref": "#/$defs/initializeBoundFacts"
          },
          "assurance_posture": {
            "const": "initialized_not_active"
          }
        }
      },
      "else": {
        "properties": {
          "sequence": {
            "type": "integer",
            "minimum": 3,
            "maximum": 9007199254740991
          },
        "bound_facts": {
          "$ref": "#/$defs/boundFacts"
          },
          "assurance_posture": {
            "const": "protected_lifecycle_committed"
          }
        }
      }
    }
  ],
