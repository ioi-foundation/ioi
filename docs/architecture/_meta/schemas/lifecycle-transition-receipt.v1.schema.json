      "type": "array",
      "maxItems": 0
    },
    "artifact_refs": {
      "type": "array",
      "maxItems": 0
    },
    "evidence_bundle_refs": {
      "type": "array",
      "maxItems": 0
    },
    "verification_ref": {
      "type": "null"
    },
    "acceptance_ref": {
      "type": "null"
    },
    "claim_scope_ref": {
