{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema://ioi/foundations/autonomous-system-activation-proposal/v1",
  "title": "AutonomousSystemActivationProposal",
  "description": "Immutable server-derived proposal for one governed Autonomous System initialize or activate effect. It is evidence only and grants no authority by itself.",
  "x-ioi-schema-version": "ioi.autonomous-system-activation-proposal.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "proposal_ref", "proposal_root", "system_id", "genesis_ref",
    "operation", "sequence", "required_scope", "operation_commitment", "authority_effect", "authority_effect_hash",
    "status", "created_at"
  ],
  "properties": {
    "schema_version": { "const": "ioi.autonomous-system-activation-proposal.v1" },
    "proposal_ref": { "$ref": "#/$defs/proposalRef" },
    "proposal_root": { "$ref": "#/$defs/hash" },
    "system_id": { "$ref": "#/$defs/systemRef" },
    "genesis_ref": { "$ref": "#/$defs/genesisRef" },
    "operation": { "$ref": "#/$defs/operation" },
    "sequence": { "enum": [1, 2] },
    "required_scope": { "$ref": "#/$defs/requiredScope" },
    "operation_commitment": { "$ref": "#/$defs/hash" },
    "authority_effect": { "$ref": "#/$defs/authorityEffect" },
    "authority_effect_hash": { "$ref": "#/$defs/hash" },
    "status": { "const": "proposed" },
    "created_at": { "$ref": "#/$defs/canonicalDateTime" }
  },
  "allOf": [
    {
      "if": { "properties": { "operation": { "const": "initialize" } }, "required": ["operation"] },
      "then": {
        "properties": {
          "sequence": { "enum": [1] },
          "required_scope": { "const": "scope:autonomous_system.lifecycle.initialize" },
          "authority_effect": {
            "type": "object",
            "properties": {
              "operation": { "const": "initialize" },
              "sequence": { "enum": [1] },
              "required_scope": { "const": "scope:autonomous_system.lifecycle.initialize" },
              "predecessor_proposal_ref": { "type": "null" },
              "predecessor_proposal_root": { "type": "null" },
              "predecessor_decision_ref": { "type": "null" },
              "predecessor_decision_root": { "type": "null" },
              "predecessor_transition_ref": { "type": "null" },
              "predecessor_transition_root": { "type": "null" },
              "predecessor_receipt_ref": { "type": "null" },
              "predecessor_receipt_root": { "type": "null" },
              "predecessor_state_ref": { "type": "null" },
              "home_domain_binding_ref": { "type": "null" },
              "home_domain_binding_root": { "type": "null" },
              "active_profile_set_ref": { "type": "null" },
              "active_profile_set_root": { "type": "null" },
              "chain_ref": { "type": "null" },
              "live_chain_created": { "const": false }
            }
          }
        }
      },
      "else": {
        "properties": {
          "sequence": { "enum": [2] },
          "required_scope": { "const": "scope:autonomous_system.lifecycle.activate" },
          "authority_effect": {
            "type": "object",
            "properties": {
              "operation": { "const": "activate" },
              "sequence": { "enum": [2] },
              "required_scope": { "const": "scope:autonomous_system.lifecycle.activate" },
              "predecessor_proposal_ref": { "$ref": "#/$defs/proposalRef" },
              "predecessor_proposal_root": { "$ref": "#/$defs/hash" },
              "predecessor_decision_ref": { "$ref": "#/$defs/decisionRef" },
              "predecessor_decision_root": { "$ref": "#/$defs/hash" },
              "predecessor_transition_ref": { "$ref": "#/$defs/transitionRef" },
              "predecessor_transition_root": { "$ref": "#/$defs/hash" },
              "predecessor_receipt_ref": { "$ref": "#/$defs/receiptRef" },
              "predecessor_receipt_root": { "$ref": "#/$defs/hash" },
              "predecessor_state_ref": { "$ref": "#/$defs/stateRef" },
              "home_domain_binding_ref": { "$ref": "#/$defs/homeDomainBindingRef" },
              "home_domain_binding_root": { "$ref": "#/$defs/hash" },
              "active_profile_set_ref": { "$ref": "#/$defs/activeProfileSetRef" },
              "active_profile_set_root": { "$ref": "#/$defs/hash" },
              "chain_ref": { "$ref": "#/$defs/chainRef" },
              "live_chain_created": { "const": true }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "nullableHash": { "anyOf": [{ "$ref": "#/$defs/hash" }, { "type": "null" }] },
    "canonicalRef": { "type": "string", "pattern": "^[a-z][a-z0-9.-]*(?:://|:)[^\\s]{1,248}$" },
    "nullableCanonicalRef": { "anyOf": [{ "$ref": "#/$defs/canonicalRef" }, { "type": "null" }] },
    "systemRef": { "type": "string", "pattern": "^system://[^\\s]{1,248}$" },
    "genesisRef": { "type": "string", "pattern": "^genesis://[^\\s]{1,248}$" },
    "proposalRef": { "type": "string", "pattern": "^proposal://[^\\s]{1,248}$" },
    "nullableProposalRef": { "anyOf": [{ "$ref": "#/$defs/proposalRef" }, { "type": "null" }] },
    "stateRef": { "type": "string", "pattern": "^system-activation-state://[^\\s]{1,248}$" },
    "nullableStateRef": { "anyOf": [{ "$ref": "#/$defs/stateRef" }, { "type": "null" }] },
    "transitionRef": { "type": "string", "pattern": "^lifecycle-transition://[^\\s]{1,248}$" },
    "nullableTransitionRef": { "anyOf": [{ "$ref": "#/$defs/transitionRef" }, { "type": "null" }] },
    "receiptRef": { "type": "string", "pattern": "^receipt://[^\\s]{1,248}$" },
    "nullableReceiptRef": { "anyOf": [{ "$ref": "#/$defs/receiptRef" }, { "type": "null" }] },
    "decisionRef": { "type": "string", "pattern": "^decision://[^\\s]{1,248}$" },
    "nullableDecisionRef": { "anyOf": [{ "$ref": "#/$defs/decisionRef" }, { "type": "null" }] },
    "activeProfileSetRef": { "type": "string", "pattern": "^active-profile-set://[^\\s]{1,248}$" },
    "nullableActiveProfileSetRef": { "anyOf": [{ "$ref": "#/$defs/activeProfileSetRef" }, { "type": "null" }] },
    "deploymentRevisionRef": { "type": "string", "pattern": "^deployment-profile://[^\\s?#\\\\]{1,160}/revision/sha256:[0-9a-f]{64}$" },
    "homeDomainRef": { "type": "string", "pattern": "^agentgres://domain/autonomous-system/[A-Za-z0-9][A-Za-z0-9._~:@/-]{0,160}/sha256:[0-9a-f]{64}$" },
    "homeDomainBindingRef": { "type": "string", "pattern": "^system-home-domain-binding://[^\\s?#\\\\]{1,160}/sha256:[0-9a-f]{64}$" },
    "nullableHomeDomainBindingRef": { "anyOf": [{ "$ref": "#/$defs/homeDomainBindingRef" }, { "type": "null" }] },
    "chainRef": { "type": "string", "pattern": "^autonomous-system-chain://[^\\s]{1,248}$" },
    "nullableChainRef": { "anyOf": [{ "$ref": "#/$defs/chainRef" }, { "type": "null" }] },
    "policyRef": { "type": "string", "pattern": "^policy://[^\\s]{1,248}$" },
    "operation": { "enum": ["initialize", "activate"] },
    "requiredScope": { "enum": ["scope:autonomous_system.lifecycle.initialize", "scope:autonomous_system.lifecycle.activate"] },
    "canonicalDateTime": {
      "type": "string", "format": "date-time",
      "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:(?:[0-5][0-9]|60)(?:[.][0-9]+|)(?:Z|[+-](?:[01][0-9]|2[0-3]):[0-5][0-9])$"
    },
    "authorityEffect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version", "operation", "required_scope", "sequence", "system_id", "genesis_ref",
        "source_governing_authority_ref",
        "genesis_admission_record_root", "genesis_admission_receipt_ref", "genesis_admission_receipt_root",
        "package_id", "manifest_ref", "admitted_manifest_root", "lifecycle_profile_ref", "profile_bundle_root",
        "sequence_zero_materialization_id", "sequence_zero_materialization_root", "sequence_zero_receipt_ref",
        "sequence_zero_receipt_root", "sequence_zero_receipt_artifact_root", "component_registry_ref",
        "component_registry_root", "materialization_wallet_consumption_ref", "materialization_wallet_consumption_root",
        "deployment_profile_ref", "deployment_profile_root", "home_domain_ref", "home_domain_commitment", "home_domain_binding_ref",
        "home_domain_binding_root", "policy_root", "module_registry_root", "upgrade_policy_ref",
        "operation_commitment", "predecessor_proposal_ref", "predecessor_proposal_root",
        "predecessor_decision_ref", "predecessor_decision_root", "predecessor_transition_ref",
        "predecessor_transition_root", "predecessor_receipt_ref", "predecessor_receipt_root",
        "predecessor_state_ref", "predecessor_state_root", "resulting_state_ref", "resulting_state_root",
        "active_profile_set_ref", "active_profile_set_root", "chain_ref", "live_chain_created", "node_membership_created",
        "runtime_effect_admitted", "network_effect_admitted"
      ],
      "properties": {
        "schema_version": { "const": "ioi.autonomous-system-lifecycle-authority-effect.v1" },
        "operation": { "$ref": "#/$defs/operation" },
        "required_scope": { "$ref": "#/$defs/requiredScope" },
        "sequence": { "enum": [1, 2] },
        "system_id": { "$ref": "#/$defs/systemRef" },
        "genesis_ref": { "$ref": "#/$defs/genesisRef" },
        "source_governing_authority_ref": { "$ref": "#/$defs/canonicalRef" },
        "genesis_admission_record_root": { "$ref": "#/$defs/hash" },
        "genesis_admission_receipt_ref": { "$ref": "#/$defs/receiptRef" },
        "genesis_admission_receipt_root": { "$ref": "#/$defs/hash" },
        "package_id": { "$ref": "#/$defs/canonicalRef" },
        "manifest_ref": { "$ref": "#/$defs/canonicalRef" },
        "admitted_manifest_root": { "$ref": "#/$defs/hash" },
        "lifecycle_profile_ref": { "$ref": "#/$defs/canonicalRef" },
        "profile_bundle_root": { "$ref": "#/$defs/hash" },
        "sequence_zero_materialization_id": { "$ref": "#/$defs/canonicalRef" },
        "sequence_zero_materialization_root": { "$ref": "#/$defs/hash" },
        "sequence_zero_receipt_ref": { "$ref": "#/$defs/receiptRef" },
        "sequence_zero_receipt_root": { "$ref": "#/$defs/hash" },
        "sequence_zero_receipt_artifact_root": { "$ref": "#/$defs/hash" },
        "component_registry_ref": { "$ref": "#/$defs/canonicalRef" },
        "component_registry_root": { "$ref": "#/$defs/hash" },
        "materialization_wallet_consumption_ref": { "$ref": "#/$defs/canonicalRef" },
        "materialization_wallet_consumption_root": { "$ref": "#/$defs/hash" },
        "deployment_profile_ref": { "$ref": "#/$defs/deploymentRevisionRef" },
        "deployment_profile_root": { "$ref": "#/$defs/hash" },
        "home_domain_ref": { "$ref": "#/$defs/homeDomainRef" },
        "home_domain_commitment": { "$ref": "#/$defs/hash" },
        "home_domain_binding_ref": { "$ref": "#/$defs/nullableHomeDomainBindingRef" },
        "home_domain_binding_root": { "$ref": "#/$defs/nullableHash" },
        "policy_root": { "$ref": "#/$defs/hash" },
        "module_registry_root": { "$ref": "#/$defs/hash" },
        "upgrade_policy_ref": { "$ref": "#/$defs/policyRef" },
        "operation_commitment": { "$ref": "#/$defs/hash" },
        "predecessor_proposal_ref": { "$ref": "#/$defs/nullableProposalRef" },
        "predecessor_proposal_root": { "$ref": "#/$defs/nullableHash" },
        "predecessor_decision_ref": { "$ref": "#/$defs/nullableDecisionRef" },
        "predecessor_decision_root": { "$ref": "#/$defs/nullableHash" },
        "predecessor_transition_ref": { "$ref": "#/$defs/nullableTransitionRef" },
        "predecessor_transition_root": { "$ref": "#/$defs/nullableHash" },
        "predecessor_receipt_ref": { "$ref": "#/$defs/nullableReceiptRef" },
        "predecessor_receipt_root": { "$ref": "#/$defs/nullableHash" },
        "predecessor_state_ref": { "$ref": "#/$defs/nullableStateRef" },
        "predecessor_state_root": { "$ref": "#/$defs/hash" },
        "resulting_state_ref": { "$ref": "#/$defs/stateRef" },
        "resulting_state_root": { "$ref": "#/$defs/hash" },
        "active_profile_set_ref": { "$ref": "#/$defs/nullableActiveProfileSetRef" },
        "active_profile_set_root": { "$ref": "#/$defs/nullableHash" },
        "chain_ref": { "$ref": "#/$defs/nullableChainRef" },
        "live_chain_created": { "type": "boolean" },
        "node_membership_created": { "const": false },
        "runtime_effect_admitted": { "const": false },
        "network_effect_admitted": { "const": false }
      }
    }
  }
}
