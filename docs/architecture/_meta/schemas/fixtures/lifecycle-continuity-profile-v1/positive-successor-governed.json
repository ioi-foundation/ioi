  },
  "dissolution": {
    "trigger_policy_refs": ["policy://acme/lifecycle/dissolution-trigger"],
    "approval_policy_ref": "policy://acme/lifecycle/dissolution-approval",
    "active_work_disposition_policy_ref": "policy://acme/lifecycle/work-disposition",
    "asset_disposition_contract_refs": [],
    "outstanding_obligation_policy_ref": "policy://acme/lifecycle/obligations",
    "authority_revocation_policy_ref": "policy://acme/lifecycle/revoke-authority",
    "worker_and_node_shutdown_policy_ref": "policy://acme/lifecycle/shutdown",
    "data_export_retention_and_erasure_policy_ref": "policy://acme/lifecycle/data-disposition",
    "network_exit_policy_ref": "policy://acme/lifecycle/network-exit",
    "tombstone_policy_ref": "policy://acme/lifecycle/tombstone"
