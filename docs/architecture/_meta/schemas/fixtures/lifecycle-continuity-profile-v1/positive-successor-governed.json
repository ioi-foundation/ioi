    "state_root_and_lineage_proof_required": true
  },
  "adoption": {
    "allowed": false,
    "adoption_policy_ref": "policy://acme/lifecycle/adoption",
    "identity_continuity_decision_profile_ref": "policy://acme/lifecycle/identity-continuity",
    "explicit_identity_decision_required": true,
    "state_root_and_lineage_proof_required": true
