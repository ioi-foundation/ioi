        "encoding": null,
        "body": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <title>Interactive Dashboard for Product Launch Metrics & Customer Feedback</title>\n    <style>\n        body { font-family: 'Arial Black', Gadget, sans-serif; }\n        .hero { text-align: center; padding-top: 70px; }\n        .controls { display: flex; justify-content: space-around; margin-bottom: 30px; }\n        .chart, .evidence { width: 100%; max-width: 800px; margin: auto; }\n    </style>\n</head>\n<body>\n    <main>\n        <section class=\"hero\">\n            <h1>Interactive Dashboard for Product Launch Metrics & Customer Feedback</h1>\n        </section>\n        <nav class=\"controls\">\n            <button type=\"button\" data-view=\"q1-sales-figures-for-dog-shampoos\" aria-controls=\"q1-sales-figures-for-dog-shampoos-panel\">Q1 Sales Figures for Dog Shampoos</button>\n            <button type=\"button\" data-view=\"customer-feedback-on-new-product-features\" aria-controls=\"customer-feedback-on-new-product-features-panel\">Customer Feedback on New Product Features</button>\n            <button type=\"button\" data-view=\"product-launch-overview\" aria-controls=\"product-launch-overview-panel\">Product Launch Overview</button>\n        </nav>\n        <section id=\"q1-sales-figures-for-dog-shampoos-panel\" class=\"chart data-view-panel=q1-sales-figures-for-dog-shampoos\" data-active>\n            <h2>Q1 Sales Figures for Dog Shampoos</h2>\n            <svg viewBox=\"0 0 800 400\">\n                \n                <rect x=\"50\" y=\"300\" width=\"600\" height=\"50\" fill=\"#FFD700\" tabindex=\"0\" data-detail=\"Q1 Sales\"></rect>\n                <text x=\"100\" y=\"280\" font-size=\"20\">Q1 Sales</text>\n            </svg>\n        </section>\n        <section id=\"customer-feedback-on-new-product-features-panel\" class=\"evidence data-view-panel=customer-feedback-on-new-product-features\">\n            <h2>Customer Feedback on New Product Features</h2>\n            <p>Customer feedback: 4.5 stars out of 5, based on 100 reviews.</p>\n        </section>\n        <section id=\"product-launch-overview-panel\" class=\"evidence data-view-panel=product-launch-overview\">\n            <h2>Product Launch Overview</h2>\n            <p>Provide an enterprise-level interactive dashboard for reviewing key metrics and customer feedback during a product launch.</p>\n        </section>\n    <aside data-studio-normalized=\"true\" data-studio-shared-detail=\"true\"><h2>Detail</h2><p id=\"detail-copy\">Q1 Sales Figures for Dog Shampoos is selected by default.</p></aside><section data-studio-normalized=\"true\" data-studio-rollover-chip-rail=\"true\"><h2>Evidence highlights</h2><div class=\"studio-rollover-chip-rail\"><button type=\"button\" class=\"studio-rollover-chip\" data-detail=\"Q1 sales figures for dog shampoos\">Q1 sales figures for dog shampoos</button><button type=\"button\" class=\"studio-rollover-chip\" data-detail=\"Customer feedback on new\">Customer feedback on new</button></div><p>Select, hover, or focus a highlight to inspect the shared detail panel.</p></section></main>\n    <script>\n        document.querySelectorAll('[data-view]').forEach((control) => {\n            control.addEventListener('click', (event) => {\n                const view = event.target.dataset.view;\n                const panels = Array.from(document.querySelectorAll('[data-view-panel]'));\n                panels.forEach(panel => {\n                    panel.setAttribute('aria-hidden', true);\n                    if (panel.getAttribute('data-view-panel') === view) {\n                        panel.removeAttribute('aria-hidden');\n                        document.querySelector('[aria-controls=' + panel.id + ']').focus();\n                    }\n                });\n            });\n        });\n    </script>\n<script data-studio-normalized=\"true\" data-studio-rollover-repair=\"true\">(() => {\n  const detailCopy = document.getElementById('detail-copy');\n  if (!detailCopy) {\n    return;\n  }\n  document.querySelectorAll('[data-detail]').forEach((mark) => {\n    if (!mark.hasAttribute('tabindex')) {\n      mark.setAttribute('tabindex', '0');\n    }\n    const updateDetail = () => {\n      const detail = mark.getAttribute('data-detail') || '';\n      if (detail) {\n        detailCopy.textContent = detail;\n      }\n    };\n    mark.addEventListener('click', updateDetail);\n    mark.addEventListener('mouseenter', updateDetail);\n    mark.addEventListener('focus', updateDetail);\n  });\n})();</script></body>\n</html>"
