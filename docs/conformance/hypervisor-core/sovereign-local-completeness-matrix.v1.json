  "evaluation_rules": {
    "case_evaluation": "expected case verdict defaults to pass; a case passes only when observed operation disposition and expected subject report verdict match the scenario, so an expected incomplete subject report is a passing evaluator self-test rather than an incomplete claim",
    "claim_dependencies": "transitive_and_must_pass",
    "execution_case_identity": "bind scenario id, all fixture ids and hashes, overlay ids and hashes, the inspectable case-parameter manifest ref and hash, and predecessor report and evidence hashes into one execution_case_id",
    "fixture_execution": "execute each selected scenario against every directly required compatible fixture unless fixture_binding is joint_all_listed_fixtures; prerequisite claims retain and execute their own fixtures and evidence cannot be reused across fixture hashes",
    "missing_required_evidence": "incomplete",
    "overlay_execution": "begin each overlay from the passing predecessor claim state; predecessor report and evidence refs and hashes are mandatory for every overlay execution case",
    "scenario_selection": "execute every scenario whose required_for_claims names the claim; this index is the sole requirement-to-claim mapping",
    "unknown_disposition_or_verdict": "invalid_matrix"
  },
  "operation_disposition_vocabulary": [
    "available",
