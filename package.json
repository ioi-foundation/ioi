{
  "name": "ioi-network-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "install:all": "npm install",
    "inspect:traineddata": "node ./scripts/inspect-traineddata.mjs",
    "check:ioi-reference": "node internal-docs/reverse-engineering/ioi/verify.js",
    "dev:hypervisor-app": "npm run dev --workspace=@ioi/hypervisor-app",
    "dev:hypervisor-web": "npm run dev --workspace=@ioi/hypervisor-web",
    "build:hypervisor-web": "npm run build --workspace=@ioi/hypervisor-web",
    "dev:hypervisor-code-editor-adapter-host": "node scripts/launch-hypervisor-code-editor-adapter-host.mjs",
    "dev:hypervisor-code-editor-adapter-host:wayland": "node scripts/launch-hypervisor-code-editor-adapter-host.mjs --ozone-platform=wayland",
    "dryrun:hypervisor-code-editor-adapter-host": "bash apps/hypervisor/scripts/dry-run-desktop.sh x11",
    "dryrun:hypervisor-code-editor-adapter-host:wayland": "bash apps/hypervisor/scripts/dry-run-desktop.sh wayland",
    "test:hypervisor-app-harness": "node --test scripts/lib/hypervisor-app-harness-contract.test.mjs",
    "build:agent-sdk": "npm run build --workspace=@ioi/agent-sdk",
    "test:agent-sdk": "npm test --workspace=@ioi/agent-sdk",
    "build:wallet-protocol": "npm run build --workspace=@ioi/wallet-protocol",
    "test:wallet-protocol": "npm test --workspace=@ioi/wallet-protocol",
    "build:wallet-sdk": "npm run build --workspace=@ioi/wallet-sdk",
    "test:wallet-sdk": "npm test --workspace=@ioi/wallet-sdk",
    "check:wallet-protocol": "node scripts/check-wallet-protocol-generated.mjs",
    "check:wallet-packaging": "npm run check:wallet-protocol && npm run test:wallet-protocol && npm run test:wallet-sdk && npm run build:wallet-protocol && npm run build:wallet-sdk",
    "check:candidate-evidence": "node scripts/check-candidate-evidence-conformance.mjs",
    "check:service-composition-evidence": "node scripts/check-service-composition-evidence.mjs",
    "check:artifact-availability-incident": "node scripts/check-artifact-availability-incident.mjs",
    "check:conformance-docs": "node scripts/check-conformance-docs.mjs && node --test scripts/test-conformance-docs-integrity.mjs",
    "hypervisor-conformance": "node scripts/conformance/hypervisor-conformance.mjs",
    "hypervisor-conformance:docs": "node scripts/conformance/hypervisor-conformance.mjs docs",
    "hypervisor-conformance:abi": "node scripts/conformance/hypervisor-conformance.mjs abi",
    "hypervisor-conformance:bridge": "node scripts/conformance/hypervisor-conformance.mjs bridge",
    "hypervisor-conformance:receipts": "node scripts/conformance/hypervisor-conformance.mjs receipts",
    "hypervisor-conformance:app": "node scripts/conformance/hypervisor-conformance.mjs app",
    "hypervisor-conformance:compositor": "node scripts/conformance/hypervisor-conformance.mjs compositor",
    "hypervisor-conformance:negative": "node scripts/conformance/hypervisor-conformance.mjs negative",
    "hypervisor-conformance:wallet": "node scripts/conformance/hypervisor-conformance.mjs wallet",
    "hypervisor-conformance:candidates": "node scripts/conformance/hypervisor-conformance.mjs candidates",
    "test:cursor-sdk-reference": "node --test scripts/lib/cursor-sdk-reference-contract.test.mjs",
    "test:rust-daemon-runtime-api": "node --test scripts/lib/rust-daemon-lifecycle-contract.test.mjs scripts/lib/rust-daemon-doctor-authority-contract.test.mjs scripts/lib/rust-daemon-coding-tools-contract.test.mjs scripts/lib/rust-daemon-workflow-edit-contract.test.mjs scripts/lib/rust-daemon-workflow-edit-approval-contract.test.mjs scripts/lib/rust-daemon-mcp-control-contract.test.mjs scripts/lib/rust-daemon-computer-use-contract.test.mjs scripts/lib/rust-daemon-computer-use-native-browser-contract.test.mjs scripts/lib/rust-daemon-computer-use-visual-gui-contract.test.mjs scripts/lib/rust-daemon-mcp-discovery-contract.test.mjs",
    "test:sdk-live-daemon": "npm test --workspace=@ioi/agent-sdk",
    "test:runtime-events": "node --test scripts/lib/architectural-improvements-broad-contract.test.mjs",
    "test:mcp-skills-hooks": "node --test scripts/lib/architectural-improvements-broad-contract.test.mjs",
    "test:subagents": "node --test scripts/lib/architectural-improvements-broad-contract.test.mjs",
    "test:workflow-compositor-dogfood": "node --test scripts/lib/rust-daemon-workflow-edit-contract.test.mjs scripts/lib/rust-daemon-workflow-edit-approval-contract.test.mjs",
    "validate:model-mounting:e2e": "node scripts/validate-model-mounting-e2e.mjs",
    "check:model-mounting-guide": "node scripts/check-model-mounting-master-guide.mjs",
    "validate:model-mounting:closeout": "node scripts/validate-model-mounting-closeout.mjs",
    "validate:model-mounting:closeout:local": "node scripts/validate-model-mounting-closeout.mjs --allow-live-skips",
    "check:runtime-layout": "node scripts/check-runtime-layout.mjs",
    "check:hypervisor-code-editor-adapter-host-paths": "node scripts/check-hypervisor-code-editor-adapter-host-paths.mjs",
    "generate:runtime-action-contracts": "node scripts/generate-runtime-action-contracts.mjs --write",
    "generate:architecture-contracts": "node scripts/generate-architecture-contracts.mjs --write",
    "check:architecture-contracts": "node scripts/check-architecture-contracts.mjs",
    "test:architecture-contract-projections": "node --experimental-strip-types scripts/test-architecture-contract-projections.mjs",
    "check:architecture-contract-bar": "node scripts/generate-architecture-contracts.mjs --check && npm run check:architecture-contracts && npm run test:architecture-contract-projections && node --test scripts/test-architecture-docs-integrity.mjs && cargo test --locked -p ioi-types architecture_contracts",
    "test:system-genesis-compiler": "cargo test --locked -p ioi-types system_genesis",
    "check:system-genesis-compiler": "node --test scripts/test-system-genesis-compiler.mjs && node scripts/check-system-genesis-compiler.mjs --check && npm run test:system-genesis-compiler",
    "dev:web": "npm run dev --workspace=@ioi/hypervisor-app",
    "dev:benchmarks": "npm run dev --workspace=apps/benchmarks",
    "build:benchmarks": "npm run build --workspace=apps/benchmarks",
    "test:benchmarks": "node --test scripts/run-agent-model-matrix.test.mjs && node --test scripts/lib/agent-model-matrix.test.mjs && npm run test:generate-data --workspace=apps/benchmarks && npm run test:viewmodel --workspace=apps/benchmarks",
    "verify:benchmarks-generated": "node ./scripts/verify-benchmarks-generated.mjs",
    "verify:benchmarks": "npm run test:benchmarks && npm run typecheck:benchmarks && npm run verify:benchmarks-generated",
    "typecheck:benchmarks": "npm run typecheck --workspace=apps/benchmarks",
    "build:workbench": "npm run build --workspace=@ioi/hypervisor-workbench",
    "build:workspace-substrate": "npm run build --workspace=@ioi/workspace-substrate",
    "build:all": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "check:m0-program-control": "node --test scripts/lib/m0-program-control.test.mjs && node scripts/m0-program-control.mjs --check",
    "check:architecture-docs": "node scripts/check-architecture-docs.mjs",
    "check:pre-next-leg": "node scripts/check-pre-next-leg.mjs",
    "check:work-items": "node scripts/check-work-items.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "mdast-util-from-markdown": "^2.0.2",
    "playwright": "^1.60.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1"
  }
}
