{
  "name": "ioi-network-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "install:all": "npm install",
    "inspect:traineddata": "node ./scripts/inspect-traineddata.mjs",
    "dev:desktop": "bash apps/autopilot/scripts/dev-desktop.sh x11",
    "dev:desktop:wayland": "bash apps/autopilot/scripts/dev-desktop.sh wayland",
    "probe:desktop:workspace": "python3 apps/autopilot/scripts/desktop_workspace_probe.py",
    "probe:desktop:workspace:activity": "python3 apps/autopilot/scripts/desktop_workspace_activity_probe.py",
    "probe:desktop:workspace:toolbar": "python3 apps/autopilot/scripts/desktop_workspace_toolbar_probe.py",
    "probe:desktop:workspace:layout": "python3 apps/autopilot/scripts/desktop_workspace_layout_probe.py",
    "probe:desktop:workspace:panel": "python3 apps/autopilot/scripts/desktop_workspace_panel_probe.py",
    "probe:desktop:workspace:dock": "python3 apps/autopilot/scripts/desktop_workspace_dock_probe.py",
    "probe:desktop:workspace:editor": "python3 apps/autopilot/scripts/desktop_workspace_editor_probe.py",
    "probe:desktop:workspace:split": "python3 apps/autopilot/scripts/desktop_workspace_split_probe.py",
    "probe:desktop:workspace:sidebar-footer": "python3 apps/autopilot/scripts/desktop_workspace_sidebar_footer_probe.py",
    "dryrun:desktop": "bash apps/autopilot/scripts/dry-run-desktop.sh x11",
    "dryrun:desktop:wayland": "bash apps/autopilot/scripts/dry-run-desktop.sh wayland",
    "validate:autopilot-gui-harness": "node scripts/run-autopilot-gui-harness-validation.mjs --preflight",
    "validate:autopilot-gui-harness:run": "node scripts/run-autopilot-gui-harness-validation.mjs --run",
    "test:autopilot-gui-harness": "node --test scripts/lib/autopilot-gui-harness-contract.test.mjs",
    "test:agent-runtime-p3": "node --test scripts/lib/agent-runtime-p3-contract.test.mjs",
    "validate:agent-runtime-p3": "node scripts/run-agent-runtime-p3-validation.mjs",
    "test:agent-runtime-superiority": "node --test scripts/lib/agent-runtime-superiority-contract.test.mjs",
    "validate:agent-runtime-superiority": "node scripts/run-agent-runtime-superiority-validation.mjs",
    "build:agent-sdk": "npm run build --workspace=@ioi/agent-sdk",
    "test:agent-sdk": "npm test --workspace=@ioi/agent-sdk",
    "test:cursor-sdk-reference": "node --test scripts/lib/cursor-sdk-reference-contract.test.mjs",
    "test:cursor-sdk-parity": "npm run build:agent-sdk && node --test scripts/lib/cursor-sdk-reference-contract.test.mjs scripts/lib/cursor-sdk-parity-contract.test.mjs",
    "validate:cursor-sdk-parity": "node scripts/run-cursor-sdk-parity-validation.mjs",
    "dev:web": "npm run dev --workspace=apps/autopilot",
    "dev:benchmarks": "npm run dev --workspace=apps/benchmarks",
    "build:benchmarks": "npm run build --workspace=apps/benchmarks",
    "test:benchmarks": "node --test scripts/run-agent-model-matrix.test.mjs && node --test scripts/lib/agent-model-matrix.test.mjs && npm run test:generate-data --workspace=apps/benchmarks && npm run test:viewmodel --workspace=apps/benchmarks",
    "verify:benchmarks-generated": "node ./scripts/verify-benchmarks-generated.mjs",
    "verify:benchmarks": "npm run test:benchmarks && npm run typecheck:benchmarks && npm run verify:benchmarks-generated",
    "typecheck:benchmarks": "npm run typecheck --workspace=apps/benchmarks",
    "build:ide": "npm run build --workspace=@ioi/agent-ide",
    "build:workspace-substrate": "npm run build --workspace=@ioi/workspace-substrate",
    "build:all": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  }
}
