{
  "name": "ioi-workbench",
  "displayName": "IOI Code Adapter",
  "description": "IOI-native code editor adapter for Hypervisor sessions.",
  "version": "0.0.1",
  "publisher": "ioi",
  "engines": {
    "vscode": "^1.109.0"
  },
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:ioi.commandCenter.open",
    "onCommand:ioi.code.open",
    "onCommand:ioi.hypervisor.back"
  ],
  "main": "./extension.js",
  "browser": "./extension.js",
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "contributes": {
    "commands": [
      {
        "command": "ioi.commandCenter.open",
        "title": "IOI: Open Hypervisor Home",
        "category": "IOI",
        "icon": "$(search)"
      },
      {
        "command": "ioi.code.open",
        "title": "IOI: Open Code Editor Adapter",
        "category": "IOI",
        "icon": "$(code)"
      },
      {
        "command": "ioi.hypervisor.back",
        "title": "IOI: Back to Hypervisor",
        "category": "IOI",
        "icon": "$(arrow-left)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "ioi.code.open"
        },
        {
          "command": "ioi.hypervisor.back"
        }
      ]
    }
  }
}
