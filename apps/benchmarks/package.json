{
  "name": "benchmarks",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "generate:data": "node ./scripts/generate-benchmark-data.mjs",
    "dev": "npm run generate:data && vite --host 0.0.0.0 --port 4177",
    "build": "npm run generate:data && tsc -b && vite build",
    "preview": "vite preview",
    "test:generate-data": "node --test ./scripts/generate-benchmark-data.test.mjs",
    "test:viewmodel": "npm run generate:data && node --experimental-strip-types --test --test-concurrency=1 ./src/appShellState.test.mjs ./src/scorecardViewModel.test.mjs ./src/scorecardPanels.render.test.mjs ./src/appShell.render.test.mjs",
    "typecheck": "npm run generate:data && tsc -b"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  }
}
